# k6 Browser Performance Framework — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# Grafana Cloud k6 integration
K6_CLOUD_TOKEN=your_grafana_cloud_token_here
K6_CLOUD_STACK_ID=your_stack_id_here
K6_CLOUD_HOST=ingest.k6.io

# Run options (optional overrides)
LOCALE=eu          # Run single locale (leave empty for all)
ITERATIONS=15      # Iterations per VU
